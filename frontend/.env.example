# Frontend environment variables
# Copy this to frontend/.env.local for local development
# Set these as Environment Variables in Vercel dashboard for production

# Backend API URL — your Render service URL (no trailing slash)
# Leave empty for local dev (Vite proxy handles /api → localhost:8000)
VITE_API_URL=
# Production example:
# VITE_API_URL=https://opportunityscout-backend.onrender.com
