# ─────────────────────────────────────────────────────────────────
# Root .gitignore for OpportunityScout
# ─────────────────────────────────────────────────────────────────

# ── Secrets & environment ─────────────────────────────────────────
.env
.env.local
.env.production

# ── Python ────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
env/
*.pyc

# ── SQLite database (don't commit the DB file) ────────────────────
*.db
*.sqlite3

# ── AI provider state (runtime file, not source) ─────────────────
backend/.ai_provider.json

# ── Node / frontend ───────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/dist-ssr/
*.local

# ── Logs ─────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*

# ── OS & editors ─────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
