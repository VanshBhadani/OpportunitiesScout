# ─────────────────────────────────────────────────────────────────
# OpportunityScout — environment variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ── AI — NVIDIA NIM (primary provider) ───────────────────────────
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=minimaxai/minimax-m2.5

# ── AI — ZhipuAI GLM (fallback provider) ─────────────────────────
ZHIPUAI_API_KEY=your_zhipuai_key_here
ZHIPUAI_BASE_URL=https://api.z.ai/api/paas/v4/
ZHIPUAI_MODEL=glm-4.7-flash

# ── Email / SMTP (Gmail App Password recommended) ─────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password_here

# ── Database ──────────────────────────────────────────────────────
# Local development (SQLite):
DATABASE_URL=sqlite:///./opportunityscout.db
# Production (Supabase PostgreSQL — replace with your connection string):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-ap-south-1.pooler.supabase.com:6543/postgres

# ── CORS ──────────────────────────────────────────────────────────
# Local development:
FRONTEND_URL=http://localhost:5173
# Production (your Vercel URL — set this on Render):
# FRONTEND_URL=https://your-app.vercel.app
