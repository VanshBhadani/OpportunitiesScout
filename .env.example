# ─────────────────────────────────────────────
# OpportunityScout — environment variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ZhipuAI GLM-4-Flash API key (free tier)
ZHIPUAI_API_KEY=your_zhipuai_key_here

# Gmail SMTP credentials (use an App Password, not your main password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here

# SQLite database path (relative to backend/)
DATABASE_URL=sqlite:///./opportunityscout.db

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
